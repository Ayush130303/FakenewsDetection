    "#preapring datasets\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "df=pd.read_csv(\"train.tsv\",sep='\\t',header=None)\n",
    "print(f'the shape of train dataset is::{df.shape}')\n",
    "df_test=pd.read_csv(\"test.tsv\",sep='\\t',header=None)\n",
    "print(f'the shape of test dataset is::{df_test.shape}')\n",
    "# print(df.head())\n",
