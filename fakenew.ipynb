    "    \"context\"\n",
    "]\n",
    "df.columns=columns\n",
    "df_test.columns=columns\n",
    "\n",
    "df=df[['statement','label']]\n",
    "df_test=df_test[['statement','label']]\n",
    "\n",
    "df.dropna(inplace=True)\n",
    "df_test.dropna(inplace=True)\n",
    "\n",
    "def convert_label(x):\n",
    "    if x in [\"true\", \"mostly-true\",'half-true']:\n",
